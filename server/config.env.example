# Server Configuration
PORT=3001
NODE_ENV=development

# Frontend URL (for CORS). Local: http://localhost:5173 — Production: https://www.mettaire.com (canonical)
FRONTEND_URL=http://localhost:5173

# Security Settings
MAX_REQUESTS_PER_MINUTE=60
RATE_LIMIT_WINDOW_MS=900000

# Image Processing Settings
DEFAULT_IMAGE_QUALITY=80
DEFAULT_VIDEO_QUALITY=80
WATERMARK_ENABLED=false

# Cache Settings
CACHE_DURATION=3600

# Allowed Domains (comma-separated)
ALLOWED_DOMAINS=localhost:5173,localhost:3000,mettaire.com,www.mettaire.com,s0va.run,www.s0va.run

# FFmpeg Path (if not in system PATH)
FFMPEG_PATH=/usr/local/bin/ffmpeg

# Cloudflare R2 (required for /api/media/* — copy from R2 dashboard)
# R2_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=soluscore-media
# R2_PUBLIC_URL=  # optional, for getPublicUrl helper